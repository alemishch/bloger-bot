# ── General ──
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bloger_bot
POSTGRES_USER=bloger_bot
POSTGRES_PASSWORD=changeme_postgres_password

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# ── ChromaDB ──
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── OpenAI ──
OPENAI_API_KEY=sk-your-key-here

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# ── Telegram Parsing ──
TELEGRAM_SESSION_NAME=content_parser
TELEGRAM_SOURCE_CHANNELS=-1002210824560,-1003898782970

# ── AmoCRM ──
AMOCRM_DOMAIN=your-domain.amocrm.ru
AMOCRM_ACCESS_TOKEN=your-token

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Services Ports ──
CONTENT_SERVICE_PORT=8001
INGESTION_SERVICE_PORT=8002
LLM_SERVICE_PORT=8003
USER_SERVICE_PORT=8004
TELEGRAM_BOT_SERVICE_PORT=8005
PAYMENT_SERVICE_PORT=8006
ANALYTICS_SERVICE_PORT=8007
CRM_SERVICE_PORT=8008
PROACTIVE_PING_SERVICE_PORT=8009

# ── Whisper (local) ──
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_LANGUAGE=ru
TRANSCRIPTION_OUTPUT_DIR=./data/transcriptions
DOWNLOAD_DIR=./data/downloads